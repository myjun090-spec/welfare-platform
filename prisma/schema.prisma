generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ========== 사용자 & 인증 ==========

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  password      String
  role          String    @default("socialworker") // admin, socialworker, volunteer
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 관계
  clientConsultations  Consultation[]
  volunteerProfile     Volunteer?
  teamMemberships      TeamMember[]
  researchMemberships  ResearchMember[]
  activityLogs         ActivityLog[]
}

// ========== 복지자원 통합 DB (캡쳐2) ==========

model Resource {
  id          String   @id @default(cuid())
  name        String
  type        String   // government, local, institution
  category    String?  // 긴급복지, 의료, 식품, 교육 등
  target      String?  // 대상자
  ageRange    String?  // 연령 범위
  incomeLevel String?  // 소득 기준
  lifecycle   String?  // 생애주기
  description String?
  howToApply  String?  // 신청 방법
  contact     String?  // 연락처
  manager     String?  // 담당자
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  linkages    Linkage[]
}

model Client {
  id          String   @id @default(cuid())
  name        String
  age         Int?
  gender      String?
  familySize  Int?     // 가구 구성원 수
  incomeLevel String?  // 소득 수준
  lifecycle   String?  // 생애주기
  address     String?
  phone       String?
  needs       String?  // 주요 욕구
  riskLevel   String?  // 위기 수준
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  consultations Consultation[]
  linkages      Linkage[]
}

model Consultation {
  id          String   @id @default(cuid())
  clientId    String
  workerId    String
  step        Int      @default(1) // 1~5단계
  notes       String?
  conditions  String?  // JSON: 검색 조건
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client      Client   @relation(fields: [clientId], references: [id])
  worker      User     @relation(fields: [workerId], references: [id])
  linkages    Linkage[]
}

model Linkage {
  id              String   @id @default(cuid())
  clientId        String
  resourceId      String
  consultationId  String?
  status          String   @default("pending") // pending, linked, monitoring, completed
  assignedTo      String?  // 담당자 이름
  memo            String?
  reassessDate    DateTime?
  linkedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client          Client       @relation(fields: [clientId], references: [id])
  resource        Resource     @relation(fields: [resourceId], references: [id])
  consultation    Consultation? @relation(fields: [consultationId], references: [id])
}

// ========== 자원봉사자 관리 (캡쳐1) ==========

model Volunteer {
  id          String   @id @default(cuid())
  userId      String   @unique
  area        String   // 활동 분야
  startDate   DateTime?
  totalHours  Float    @default(0)
  status      String   @default("active") // active, resting, retired
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  activities  VolunteerActivity[]
  reports     VolunteerReport[]
}

model VolunteerActivity {
  id          String   @id @default(cuid())
  volunteerId String
  date        DateTime
  hours       Float
  location    String?
  description String?
  createdAt   DateTime @default(now())

  volunteer   Volunteer @relation(fields: [volunteerId], references: [id])
}

model VolunteerReport {
  id          String   @id @default(cuid())
  volunteerId String
  title       String
  period      String   // 보고 기간
  content     String?
  filePath    String?  // 생성된 문서 경로
  autoGenerated Boolean @default(false)
  createdAt   DateTime @default(now())

  volunteer   Volunteer @relation(fields: [volunteerId], references: [id])
}

// ========== 논문/연구 관리 (캡쳐3) ==========

model ResearchProject {
  id           String   @id @default(cuid())
  title        String
  description  String?
  currentRound Int      @default(1) // 1~4 Round
  status       String   @default("active") // active, completed, archived
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  members      ResearchMember[]
  rounds       ResearchRound[]
  files        ResearchFile[]
}

model ResearchMember {
  id         String   @id @default(cuid())
  projectId  String
  userId     String
  role       String   // coordinator, scout, analyst, writer, critic, scribe
  joinedAt   DateTime @default(now())

  project    ResearchProject @relation(fields: [projectId], references: [id])
  user       User            @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
}

model ResearchRound {
  id         String   @id @default(cuid())
  projectId  String
  roundNum   Int      // 1~4
  title      String   // Round 이름
  status     String   @default("pending") // pending, in_progress, completed
  notes      String?  // Scribe 기록
  startedAt  DateTime?
  endedAt    DateTime?
  createdAt  DateTime @default(now())

  project    ResearchProject @relation(fields: [projectId], references: [id])
}

model ResearchFile {
  id         String   @id @default(cuid())
  projectId  String
  name       String
  type       String   // paper, reference, draft, final
  filePath   String
  uploadedBy String?
  createdAt  DateTime @default(now())

  project    ResearchProject @relation(fields: [projectId], references: [id])
}

// ========== 팀 협업 관리 (캡쳐4) ==========

model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     TeamMember[]
  tasks       TeamTask[]
  outputs     TeamOutput[]
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     String   // leader, worker-a, worker-b, recorder
  joinedAt DateTime @default(now())

  team     Team @relation(fields: [teamId], references: [id])
  user     User @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
}

model TeamTask {
  id          String   @id @default(cuid())
  teamId      String
  title       String
  description String?
  assignedTo  String?  // 담당자 이름
  status      String   @default("todo") // todo, in_progress, review, done
  priority    String   @default("medium") // low, medium, high
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team        Team @relation(fields: [teamId], references: [id])
}

model TeamOutput {
  id        String   @id @default(cuid())
  teamId    String
  type      String   // code, report, minutes
  title     String
  content   String?
  filePath  String?
  author    String?
  status    String   @default("draft") // draft, review, completed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team      Team @relation(fields: [teamId], references: [id])
}

// ========== 공통: 활동 로그 ==========

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  module    String   // resources, volunteers, research, teams
  action    String   // create, update, delete, link, etc.
  target    String?  // 대상 설명
  details   String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])
}
